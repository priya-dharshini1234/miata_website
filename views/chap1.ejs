<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Chapter 1 - Basic Abdominal Ultrasound Imaging</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<style>
body{
margin:0;
font-family:'Inter',sans-serif;
background:#eef4ff;
color:#1c2b4a;
}
.course-header{
background:linear-gradient(135deg,#0f4c81,#1e6bb8);
padding:55px 80px;
color:white;
}
.course-header h1{
font-size:30px;
margin-bottom:10px;
}
.course-header p{
max-width:700px;
color:#dbe9ff;
}
.progress{ margin-top:20px; }
.progress-bar{
width:100%;
height:8px;
background:rgba(255,255,255,0.3);
border-radius:10px;
margin-top:6px;
}
.progress-fill{
width:40%;
height:100%;
background:#5ad0ff;
border-radius:10px;
}
.container{
max-width:1100px;
margin:40px auto;
padding:0 20px;
}
.lesson-card{
background:white;
padding:25px 30px;
border-radius:12px;
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
box-shadow:0 6px 18px rgba(0,0,0,0.08);
transition:0.3s;
}
.lesson-card:hover{ transform:translateY(-4px); }
.lesson-left{
display:flex;
align-items:center;
gap:18px;
}
.lesson-icon{
width:55px;
height:55px;
border-radius:50%;
background:#e6f0ff;
display:flex;
align-items:center;
justify-content:center;
font-size:20px;
color:#1e6bb8;
}
.lesson-text h3{ margin:0; font-size:18px; }
.lesson-text p{ margin:5px 0; font-size:14px; color:#6c7b94; }
.completed{ font-size:13px; color:#1e6bb8; font-weight:500; }
.lesson-btn{
background:#1e6bb8;
color:white;
border:none;
padding:10px 25px;
border-radius:6px;
cursor:pointer;
font-weight:500;
}
.lesson-btn:hover{ background:#0f4c81; }
.locked{ background:#ccc; cursor:not-allowed; }
.section{
display:none;
margin-top:30px;
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 4px 14px rgba(0,0,0,0.08);
}
.video-modal{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.9);
display:none;
justify-content:center;
align-items:center;
z-index:9999;
}
.video-modal-content{
width:90%;
max-width:1000px;
position:relative;
}
.video-modal video{
width:100%;
height:550px;
border-radius:12px;
background:black;
}
.video-modal iframe{
width:100%;
height:550px;
border-radius:12px;
background:white;
}
.close-video{
position:absolute;
top:-45px;
right:0;
color:white;
font-size:30px;
cursor:pointer;
}
input[type="file"]{
width:100%;
padding:10px;
border-radius:6px;
border:1px solid #ccd6e0;
}
#submitBtn{
margin-top:15px;
padding:10px 25px;
background:#1e6bb8;
color:white;
border:none;
border-radius:6px;
cursor:pointer;
}
#timer{ font-weight:600; color:#1e6bb8; }
@media(max-width:768px){
.course-header{ padding:30px 20px; }
.lesson-card{ flex-direction:column; align-items:flex-start; gap:15px; }
.video-modal video{ height:300px; }
.video-modal iframe{ height:300px; }
}
</style>
</head>

<body>

<div class="course-header">
  <h1>Chapter 1: Basic Abdominal Ultrasound Imaging</h1>
  <p>Introduction to abdominal ultrasound principles, anatomy and scanning techniques.</p>
</div>

<div class="container">

  <!-- VIDEO -->
  <div class="lesson-card">
    <div class="lesson-left">
      <div class="lesson-icon"><i class="fa fa-play"></i></div>
      <div class="lesson-text">
        <h3>Lecture Video</h3>
        <p>Video: 15 minutes</p>
        <div class="completed">Completed</div>
      </div>
    </div>
    <button class="lesson-btn" onclick="openVideo()">Start</button>
  </div>

  <!-- STUDY MATERIAL -->
  <div class="lesson-card">
    <div class="lesson-left">
      <div class="lesson-icon"><i class="fa fa-book-open"></i></div>
      <div class="lesson-text">
        <h3>Study Material</h3>
        <p>Reading Material</p>
      </div>
    </div>
    <button class="lesson-btn" onclick="openPDF()">Start</button>
  </div>

  <!-- ASSESSMENT -->
  <div class="lesson-card">
    <div class="lesson-left">
      <div class="lesson-icon"><i class="fa fa-question"></i></div>
      <div class="lesson-text">
        <h3>Assessment</h3>
        <p>Quiz Evaluation</p>
      </div>
    </div>
    <a href="/ass1">
      <button class="lesson-btn">Start</button>
    </a>
  </div>

  <!-- COURSEWORK -->
  <div class="lesson-card">
    <div class="lesson-left">
      <div class="lesson-icon"><i class="fa fa-upload"></i></div>
      <div class="lesson-text">
        <h3>Course Work Submission</h3>
        <p>Upload Assignment</p>
      </div>
    </div>
    <% if (coursework_start_time) { %>
      <button class="lesson-btn" onclick="showSection('coursework')">Open</button>
    <% } else { %>
      <button class="lesson-btn locked">Locked</button>
    <% } %>
  </div>

  <!-- COURSEWORK SECTION -->
  <div id="coursework" class="section">
    <p>⏱ Time Remaining: <span id="timer"></span></p>
    <form method="post" enctype="multipart/form-data">
      <input type="file" name="submission" required>
      <button id="submitBtn" type="submit">Submit</button>
    </form>
  </div>

</div>

<!-- VIDEO MODAL -->
<div class="video-modal" id="videoModal">
  <div class="video-modal-content">
    <span class="close-video" onclick="closeVideo()"><i class="fa fa-times"></i></span>
    <video id="chapterVideo" controls controlslist="nodownload noplaybackrate">
      <source src="/video/chap1.mp4" type="video/mp4">
    </video>
  </div>
</div>

<!-- PDF MODAL -->
<div class="video-modal" id="pdfModal">
  <div class="video-modal-content">
    <span class="close-video" onclick="closePDF()"><i class="fa fa-times"></i></span>
    <iframe src="/docs/chap1.pdf"></iframe>
  </div>
</div>

<script>
function openVideo(){
  document.getElementById("videoModal").style.display="flex";
}
function closeVideo(){
  const video=document.getElementById("chapterVideo");
  video.pause();
  video.currentTime=0;
  document.getElementById("videoModal").style.display="none";
}
document.getElementById("videoModal").addEventListener("click",function(e){
  if(e.target===this){ closeVideo(); }
});

function openPDF(){
  document.getElementById("pdfModal").style.display="flex";
}
function closePDF(){
  document.getElementById("pdfModal").style.display="none";
}
document.getElementById("pdfModal").addEventListener("click",function(e){
  if(e.target===this){ closePDF(); }
});

let timerStarted=false;
let startTime;
const limit=24*60*60*1000;

function showSection(id){
  document.querySelectorAll('.section').forEach(s=>s.style.display='none');
  document.getElementById(id).style.display='block';
  if(id==="coursework" && !timerStarted){
    timerStarted=true;
    startTime=Date.now();
    setInterval(updateTimer,1000);
  }
}

function updateTimer(){
  const diff=limit-(Date.now()-startTime);
  if(diff<=0){
    document.getElementById("timer").innerText="Time Over";
    document.getElementById("submitBtn").disabled=true;
    return;
  }
  const h=Math.floor(diff/3600000);
  const m=Math.floor((diff%3600000)/60000);
  const s=Math.floor((diff%60000)/1000);
  document.getElementById("timer").innerText=h+"h "+m+"m "+s+"s";
}
</script>

</body>
</html>