<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Agent Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
*{ margin:0; padding:0; box-sizing:border-box; }
body{ font-family:'Poppins',sans-serif; background:#f4f6fb; color:#1b2a4e; }
.dashboard-container{ display:flex; min-height:100vh; }
.sidebar{ width:250px; background:linear-gradient(180deg,#b5660a,#7a3f00); padding:40px 25px; color:white; }
.sidebar h3{ font-size:18px; margin-bottom:40px; font-weight:600; }
.sidebar a{ display:block; padding:12px 15px; margin-bottom:12px; text-decoration:none; color:white; border-radius:10px; font-weight:500; transition:0.3s; opacity:0.9; }
.sidebar a:hover{ background:rgba(255,255,255,0.15); }
.main-content{ flex:1; padding:50px; }
.top-bar{ display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; }
.top-bar h2{ font-size:24px; font-weight:600; }
.logout-btn{ background:#b5660a; color:white; padding:8px 20px; border-radius:20px; text-decoration:none; font-size:14px; }
.logout-btn:hover{ background:#7a3f00; }
.cards-container{ display:flex; flex-direction:column; gap:25px; }
.info-card{ width:100%; background:white; padding:30px; border-radius:18px; box-shadow:0 10px 25px rgba(0,0,0,0.06); display:flex; align-items:center; justify-content:space-between; transition:0.3s; }
.info-card:hover{ transform:translateY(-4px); }
.card-left{ display:flex; align-items:center; gap:20px; }
.card-icon{ width:60px; height:60px; background:linear-gradient(135deg,#b5660a,#7a3f00); color:white; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:24px; }
.card-text h4{ font-size:18px; margin-bottom:6px; }
.card-text p{ font-size:14px; color:#777; }
.card-btn{ background:#b5660a; color:white; padding:10px 18px; border-radius:20px; text-decoration:none; font-size:14px; transition:0.3s; }
.card-btn:hover{ background:#7a3f00; }
.role-tag{ background:#fff3e0; color:#b5660a; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; }
@media(max-width:768px){
  .dashboard-container{ flex-direction:column; }
  .sidebar{ width:100%; padding:20px; }
  .main-content{ padding:20px; }
  .info-card{ flex-direction:column; align-items:flex-start; gap:15px; }
}
</style>
</head>
<body>
<div class="dashboard-container">
  <div class="sidebar">
    <h3><i class="fas fa-handshake"></i> Agent Portal</h3>
    <a href="/dashboard/agent"><i class="fas fa-home"></i> Home</a>
    <a href="#"><i class="fas fa-users"></i> My Students</a>
    <a href="#"><i class="fas fa-file-alt"></i> Enrollments</a>
    <a href="#"><i class="fas fa-chart-bar"></i> Reports</a>
    <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
  <div class="main-content">
    <div class="top-bar">
      <div>
        <h2>Welcome, <%= user.username %> 👋</h2>
        <span class="role-tag">🤝 Agent</span>
      </div>
      <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
    <div class="cards-container">
      <div class="info-card">
        <div class="card-left">
          <div class="card-icon"><i class="fas fa-users"></i></div>
          <div class="card-text">
            <h4>Manage Students</h4>
            <p>View and manage your enrolled students.</p>
          </div>
        </div>
        <a href="#" class="card-btn">View</a>
      </div>
      <div class="info-card">
        <div class="card-left">
          <div class="card-icon"><i class="fas fa-file-alt"></i></div>
          <div class="card-text">
            <h4>Enrollment Applications</h4>
            <p>Review and process new enrollment requests.</p>
          </div>
        </div>
        <a href="#" class="card-btn">View</a>
      </div>
      <div class="info-card">
        <div class="card-left">
          <div class="card-icon"><i class="fas fa-chart-bar"></i></div>
          <div class="card-text">
            <h4>Reports</h4>
            <p>View performance and enrollment reports.</p>
          </div>
        </div>
        <a href="#" class="card-btn">View</a>
      </div>
    </div>
  </div>
</div>
</body>
</html>