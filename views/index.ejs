<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MIATA</title>
<link rel="stylesheet" href="/css/styles.css">
<style>

/* ===== TOP NAV DROPDOWN ===== */
.nav-dropdown {
  position: relative;
}
.nav-dropdown-content {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  background: white;
  min-width: 220px;
  border-radius: 8px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  z-index: 9999;
  padding: 8px 0;
}
.nav-dropdown:hover .nav-dropdown-content {
  display: block;
}
.nav-dropdown-content a {
  display: block;
  padding: 10px 16px;
  color: #333 !important;
  text-decoration: none;
  font-size: 14px;
  transition: 0.2s;
}
.nav-dropdown-content a:hover {
  background: #eef3ff;
  color: #003366 !important;
}
.nav-dropdown-content a::after {
  display: none !important;
}
.nav-dropdown-content input {
  display: block;
  margin: 8px 10px;
  width: calc(100% - 20px);
  padding: 8px 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 13px;
  outline: none;
  box-sizing: border-box;
}

/* ===== SUB NAV DROPDOWN ===== */
.sub-dropdown {
  position: relative;
  flex-shrink: 0;
}
.sub-dropdown-btn {
  color: #444;
  font-size: 14px;
  cursor: pointer;
  background: none;
  border: none;
  font-family: inherit;
  padding: 0;
  white-space: nowrap;
}
.sub-dropdown-panel {
  display: none;
  position: absolute;
  top: 30px;
  left: 0;
  background: white;
  border-radius: 10px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  width: 280px;
  z-index: 9999;
  padding: 15px;
}
.sub-dropdown:hover .sub-dropdown-panel {
  display: block;
}
.sub-list {
  list-style: none;
  margin: 0;
  padding: 0;
  max-height: 220px;
  overflow-y: auto;
}
.sub-list li a {
  display: block;
  padding: 8px 10px;
  color: #333;
  text-decoration: none;
  font-size: 13px;
  border-radius: 5px;
  transition: 0.2s;
}
.sub-list li a:hover {
  background: #eef3ff;
  color: #003366;
}
.sub-list li.hidden {
  display: none;
}

/* ===== RESPONSIVE NAV ===== */
@media (max-width: 1024px) {
  .top-nav {
    flex-wrap: wrap;
    padding: 12px 20px;
    gap: 10px;
  }
  .menu {
    flex-wrap: wrap;
    gap: 12px;
  }
  .menu a,
  .nav-dropdown > a {
    font-size: 13px;
  }
  .right-links {
    gap: 12px;
  }
}

@media (max-width: 768px) {
  .top-nav {
    flex-direction: column;
    align-items: flex-start;
    padding: 15px 20px;
    gap: 12px;
  }
  .logo img {
    height: 55px;
  }
  .menu {
    width: 100%;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
  }
  .menu a,
  .nav-dropdown > a {
    font-size: 13px;
    padding: 6px 10px;
    background: rgba(255,255,255,0.1);
    border-radius: 6px;
  }
  .right-links {
    width: 100%;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 10px;
  }
  .sub-nav {
    gap: 10px;
    padding: 10px 15px;
  }
  .sub-nav a,
  .sub-dropdown-btn {
    font-size: 12px;
  }
  .nav-dropdown-content {
    min-width: 180px;
  }
}

@media (max-width: 480px) {
  .top-nav {
    padding: 12px 15px;
  }
  .logo img {
    height: 45px;
  }
  .menu {
    gap: 6px;
  }
  .menu a,
  .nav-dropdown > a {
    font-size: 12px;
    padding: 5px 8px;
  }
  .right-links a {
    font-size: 12px;
  }
  .sub-nav {
    padding: 8px 12px;
    gap: 8px;
  }
  .sub-nav a,
  .sub-dropdown-btn {
    font-size: 11px;
  }
}
</style>
</head>
<body>

