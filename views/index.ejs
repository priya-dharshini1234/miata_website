            <div class="nav-dropdown-content">
                <a href="/study">Overview</a>
                <a href="/subjects">Subject Areas</a>
                <a href="/courses">All Courses</a>
                <a href="/apply">How to Apply</a>
            </div>
        </div>

        <!-- COURSES A-Z DROPDOWN WITH SEARCH -->
        <div class="nav-dropdown">
            <a href="/courses">Courses A-Z ▾</a>
            <div class="nav-dropdown-content">
                <input
                    type="text"
                    placeholder="🔍 Search courses..."
                    onkeyup="filterCourses(this)"
                >
                <ul class="sub-list" id="coursesList">
                    <li><a href="/courses#ultrasound">Professional Diploma in Medical Imaging – Ultrasound</a></li>
                    <li><a href="/courses#nutrition">Professional Diploma in Nutrition</a></li>
                    <li><a href="/courses#functional">Professional Diploma in Functional & Lifestyle Medicine</a></li>
                    <li><a href="/courses#endoscopy">Professional Diploma in Upper GI Endoscopy</a></li>
                </ul>
            </div>
        </div>

        <a href="/research">Research & Innovation</a>
        <a href="/faculties">Our Facilities</a>
        <a href="/about">About</a>

    </nav>

    <div class="right-links">
        <a href="/login">Login</a>
        <a href="#">🔍</a>
        <div class="currency-selector">
            <span id="currency-btn" onclick="toggleDropdown()" style="font-size:28px; cursor:pointer;">🌍</span>
            <img id="selected-flag" style="width:28px; height:20px; margin-left:6px; display:none;">
        </div>
        <ul id="countryDropdown" class="dropdown-list" style="display:none;">
            <li onclick="changeCurrency('GBP','gb')">United Kingdom</li>
            <li onclick="changeCurrency('INR','in')">India</li>
            <li onclick="changeCurrency('USD','us')">United States</li>
            <li onclick="changeCurrency('AUD','au')">Australia</li>
            <li onclick="changeCurrency('CAD','ca')">Canada</li>
        </ul>
    </div>
</header>

<!-- SUB NAVIGATION -->
<nav class="sub-nav">
    <a href="/student-services">Student Services</a>
    
    <a href="/subjects">Subject areas</a>
    <a href="/apply">How to apply</a>
    <a href="/fees">Fees & Funding</a>
    <a href="/experience">Student experience</a>
    <a href="/events">Postgraduate events</a>
    <a href="/offer-holders">Offer holders</a>
    <a href="/contact">Contact us</a>
</nav>

<!-- MAIN CONTENT -->
<main class="content">
    <h1 class="shine">Professional diploma in Medical Imaging(Ultrasound)</h1>

    <div class="slider-container">
        <div class="slider-track">
            <img src="/images/med1.jpg" alt="Medical image">
            <img src="/images/med2.jpg" alt="Medical image">
            <img src="/images/med3.jpg" alt="Medical image">
            <img src="/images/med4.jpeg" alt="Medical image">
            <img src="/images/med5.jpg" alt="Medical image">
            <img src="/images/med6.jpeg" alt="Medical image">
            <img src="/images/med7.jpg" alt="Medical image">
            <img src="/images/med8.jpg" alt="Medical image">
        </div>
    </div>
