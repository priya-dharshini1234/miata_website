    <!-- TAB BUTTONS -->
    <div class="tabs">
        <a href="#" class="tab-btn active" data-tab="overview">Overview</a>
        <a href="#" class="tab-btn" data-tab="teaching">Teaching & Modules</a>
        <a href="#" class="tab-btn" data-tab="entry">Entry requirements</a>
        <a href="#" class="tab-btn" data-tab="fees">Fees</a>
        <a href="#" class="tab-btn" data-tab="careers">Careers</a>
