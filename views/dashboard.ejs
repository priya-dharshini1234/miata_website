<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Student Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

<style>
*{ margin:0; padding:0; box-sizing:border-box; }
body{ font-family:'Poppins',sans-serif; background:#f4f6fb; color:#1b2a4e; }

.dashboard-container{ display:flex; min-height:100vh; }

.sidebar{
    width:250px;
    background:linear-gradient(180deg,#5a4bcf,#7b68ee);
    padding:40px 25px;
    color:white;
}
.sidebar h3{ font-size:20px; margin-bottom:40px; font-weight:600; }
.sidebar a{
    display:block;
    padding:12px 15px;
    margin-bottom:12px;
    text-decoration:none;
    color:white;
    border-radius:10px;
    font-weight:500;
    transition:0.3s;
    opacity:0.9;
}
.sidebar a:hover{ background:rgba(255,255,255,0.15); }

.main-content{ flex:1; padding:50px; }

.top-bar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:40px;
}
.top-bar h2{ font-size:26px; font-weight:600; }

.logout-btn{
    background:#7b68ee;
    color:white;
    padding:8px 20px;
    border-radius:20px;
    text-decoration:none;
    font-size:14px;
    transition:0.3s;
}
.logout-btn:hover{ background:#5a4bcf; }

.units-container{ display:flex; flex-direction:column; gap:25px; }

.unit-card{
    width:100%;
    background:white;
    padding:30px;
    border-radius:18px;
    box-shadow:0 10px 25px rgba(0,0,0,0.06);
    transition:0.3s;
    display:flex;
    align-items:center;
    justify-content:space-between;
}
.unit-card:hover{ transform:translateY(-4px); box-shadow:0 15px 35px rgba(0,0,0,0.1); }

.unit-left{ display:flex; align-items:center; gap:20px; }

.unit-icon{
    width:60px;
    height:60px;
    background:linear-gradient(135deg,#7b68ee,#5a4bcf);
    color:white;
    border-radius:16px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
}
.unit-text h4{ font-size:18px; margin-bottom:6px; }
.unit-text p{ font-size:14px; color:#777; }

.unit-btn{
    background:#7b68ee;
    color:white;
    padding:10px 18px;
    border-radius:20px;
    text-decoration:none;
    font-size:14px;
    transition:0.3s;
}
.unit-btn:hover{ background:#5a4bcf; }

@media(max-width:768px){
    .dashboard-container{ flex-direction:column; }
    .sidebar{ width:100%; display:flex; justify-content:space-around; align-items:center; }
    .sidebar h3{ display:none; }
    .main-content{ padding:30px; }
    .unit-card{ flex-direction:column; align-items:flex-start; gap:15px; }
    .unit-btn{ align-self:flex-start; }
}
</style>
</head>

<body>

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h3><i class="fas fa-graduation-cap"></i> Learning Portal</h3>
        <a href="#"><i class="fas fa-home"></i> Home</a>
        <a href="#"><i class="fas fa-book"></i> My Units</a>
        <a href="#"><i class="fas fa-certificate"></i> Certificate</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="top-bar">
            <h2>Welcome <%= user.username %></h2>
            <a href="/logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>

        <div class="units-container">

            <!-- Unit 1 -->
            <div class="unit-card">
                <div class="unit-left">
                    <div class="unit-icon"><i class="fas fa-book-medical"></i></div>
                    <div class="unit-text">
                        <h4>Unit 1 – Basic Abdominal Ultrasound</h4>
                        <p>Introduction to abdominal anatomy and scanning protocols.</p>
                    </div>
                </div>
                <a href="/chap1" class="unit-btn">Open</a>
            </div>

            <!-- Unit 2 -->
            <div class="unit-card">
                <div class="unit-left">
                    <div class="unit-icon"><i class="fas fa-heartbeat"></i></div>
                    <div class="unit-text">
                        <h4>Unit 2 – Obstetric Ultrasound</h4>
                        <p>Fetal development, measurements, and safety standards.</p>
                    </div>
                </div>
                <a href="#" class="unit-btn">Open</a>
            </div>

            <!-- Unit 3 -->
            <div class="unit-card">
                <div class="unit-left">
                    <div class="unit-icon"><i class="fas fa-x-ray"></i></div>
                    <div class="unit-text">
                        <h4>Unit 3 – Vascular Imaging</h4>
                        <p>Doppler techniques and vascular assessment procedures.</p>
                    </div>
                </div>
                <a href="#" class="unit-btn">Open</a>
            </div>

        </div>
    </div>
</div>

</body>
</html>