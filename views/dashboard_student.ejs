<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Student Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
*{ margin:0; padding:0; box-sizing:border-box; }
body{ font-family:'Poppins',sans-serif; background:#f4f6fb; color:#1b2a4e; }
.dashboard-container{ display:flex; min-height:100vh; }
.sidebar{ width:250px; background:linear-gradient(180deg,#1a6b3c,#0d3b21); padding:40px 25px; color:white; }
.sidebar h3{ font-size:18px; margin-bottom:40px; font-weight:600; }
.sidebar a{ display:block; padding:12px 15px; margin-bottom:12px; text-decoration:none; color:white; border-radius:10px; font-weight:500; transition:0.3s; opacity:0.9; }
.sidebar a:hover{ background:rgba(255,255,255,0.15); }
.main-content{ flex:1; padding:50px; }
.top-bar{ display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; }
.top-bar h2{ font-size:24px; font-weight:600; }
.logout-btn{ background:#1a6b3c; color:white; padding:8px 20px; border-radius:20px; text-decoration:none; font-size:14px; }
.logout-btn:hover{ background:#0d3b21; }
.units-container{ display:flex; flex-direction:column; gap:25px; }
.unit-card{ width:100%; background:white; padding:30px; border-radius:18px; box-shadow:0 10px 25px rgba(0,0,0,0.06); display:flex; align-items:center; justify-content:space-between; transition:0.3s; }
.unit-card:hover{ transform:translateY(-4px); }
.unit-left{ display:flex; align-items:center; gap:20px; }
.unit-icon{ width:60px; height:60px; background:linear-gradient(135deg,#1a6b3c,#0d3b21); color:white; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:24px; }
.unit-text h4{ font-size:18px; margin-bottom:6px; }
.unit-text p{ font-size:14px; color:#777; }
.unit-btn{ background:#1a6b3c; color:white; padding:10px 18px; border-radius:20px; text-decoration:none; font-size:14px; transition:0.3s; }
.unit-btn:hover{ background:#0d3b21; }
.role-tag{ background:#e8f5e9; color:#1a6b3c; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; }
@media(max-width:768px){
  .dashboard-container{ flex-direction:column; }
  .sidebar{ width:100%; padding:20px; }
  .main-content{ padding:20px; }
  .unit-card{ flex-direction:column; align-items:flex-start; gap:15px; }
}
</style>
</head>
<body>
<div class="dashboard-container">
  <div class="sidebar">
    <h3><i class="fas fa-graduation-cap"></i> Student Portal</h3>
    <a href="/dashboard/student"><i class="fas fa-home"></i> Home</a>
    <a href="/chap1"><i class="fas fa-book"></i> My Units</a>
    <a href="#"><i class="fas fa-certificate"></i> Certificate</a>
    <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
  <div class="main-content">
    <div class="top-bar">
      <div>
        <h2>Welcome, <%= user.username %> 👋</h2>
        <span class="role-tag">🎓 Student</span>
      </div>
      <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
    <div class="units-container">
      <div class="unit-card">
        <div class="unit-left">
          <div class="unit-icon"><i class="fas fa-book-medical"></i></div>
          <div class="unit-text">
            <h4>Unit 1 – Basic Abdominal Ultrasound</h4>
            <p>Introduction to abdominal anatomy and scanning protocols.</p>
          </div>
        </div>
        <a href="/chap1" class="unit-btn">Open</a>
      </div>
      <div class="unit-card">
        <div class="unit-left">
          <div class="unit-icon"><i class="fas fa-heartbeat"></i></div>
          <div class="unit-text">
            <h4>Unit 2 – Obstetric Ultrasound</h4>
            <p>Fetal development, measurements, and safety standards.</p>
          </div>
        </div>
        <a href="#" class="unit-btn">Locked 🔒</a>
      </div>
      <div class="unit-card">
        <div class="unit-left">
          <div class="unit-icon"><i class="fas fa-x-ray"></i></div>
          <div class="unit-text">
            <h4>Unit 3 – Vascular Imaging</h4>
            <p>Doppler techniques and vascular assessment procedures.</p>
          </div>
        </div>
        <a href="#" class="unit-btn">Locked 🔒</a>
      </div>
    </div>
  </div>
</div>
</body>
</html>